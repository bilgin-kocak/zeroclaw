# --- 0G (Galileo testnet) ---
# Get faucet funds at https://faucet.0g.ai
ZEROG_RPC_URL=https://evmrpc-testnet.0g.ai
ZEROG_PRIVATE_KEY=0x
# Turbo indexer (faster than the standard one):
ZEROG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
ZEROG_KV_ENDPOINT=http://3.101.147.150:6789
# Flow contract on Galileo testnet (per docs.0g.ai/developer-hub/testnet/testnet-overview):
ZEROG_FLOW_CONTRACT=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296
# Stream id (32-byte hex): pick any value once and keep it stable across runs.
ZEROG_STREAM_ID=0x1111111111111111111111111111111111111111111111111111111111111111
# Two distinct models from the 0G Compute live catalog. Run `pnpm zerog:list`
# to see what's currently offered, then paste the model strings here.
ZEROG_PROPOSER_MODEL=
ZEROG_CRITIC_MODEL=

# --- KeeperHub ---
# Sign up at https://keeperhub.com — verify Unichain Sepolia is supported on your tier
KEEPERHUB_API_KEY=
KEEPERHUB_MCP_URL=https://app.keeperhub.com/mcp

# --- Uniswap ---
# Production base URL is the trade-api gateway, NOT api.uniswap.org/v1
# (the latter returns ACCESS_DENIED for external keys; see UNISWAP_FEEDBACK.md).
UNISWAP_API_URL=https://trade-api.gateway.uniswap.org/v1
UNISWAP_API_KEY=

# --- ENS / chain ---
# Sepolia for ENS; Unichain Sepolia for the Uniswap swap
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
UNICHAIN_SEPOLIA_RPC_URL=https://sepolia.unichain.org
DEPLOYER_PRIVATE_KEY=0x
ENS_NAME=zeroclaw.eth
ENS_PROPOSER_SUBNAME=proposer.zeroclaw.eth
ENS_CRITIC_SUBNAME=critic.zeroclaw.eth

# --- Telegram (optional, Day 4 stretch) ---
TELEGRAM_BOT_TOKEN=

# --- Modes ---
# EXECUTION_BACKEND: mock | keeperhub | rawweb3
EXECUTION_BACKEND=mock
# INFERENCE_BACKEND: mock | zerog | openai
INFERENCE_BACKEND=mock
# OpenAI fallback (dev only)
OPENAI_API_KEY=

# --- Web UI ---
WEB_PORT=3000
